# === Instagram Graph API ===
# Obtinut dupa ce contul e Business/Creator + legat de o Pagina Facebook
# si ai trecut prin Meta App Review (permisiuni: instagram_content_publish, instagram_manage_comments)
IG_ACCESS_TOKEN=
IG_BUSINESS_ACCOUNT_ID=

# === Google Drive ===
# ID-ul folderului unde arunci randarile noi (il iei din URL-ul folderului)
GDRIVE_FOLDER_ID=
# Calea catre fisierul JSON al Service Account-ului (vezi README pentru cum il generezi)
GDRIVE_SERVICE_ACCOUNT_FILE=config/gdrive-service-account.json

# === Claude API (generare caption-uri + strategie) ===
ANTHROPIC_API_KEY=

# === Nano Banana Pro (generare/adaptare imagini) prin OpenRouter, cum ai deja configurat ===
OPENROUTER_API_KEY=

# === Formular leaduri ===
# URL-ul unde trimiti leadurile captate
LEAD_FORM_URL=

# === Brand / stil ===
BRAND_NAME=bmdesign.ro
